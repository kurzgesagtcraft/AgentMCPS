# MCPO Plugin Configuration
# VCPChat 使用独立端口 8999，避免与 KiloCode 的 9999 端口冲突
MCPO_PORT=8999
MCPO_API_KEY=vcp-mcpo-secret
MCPO_AUTO_START=true
PYTHON_EXECUTABLE=python

MCP_CONFIG_PATH=./Plugin/MCPO/custom-mcp-config/mcp-config.json
# 注意此处相对路径是以 VCPToolBox 作为根目录
# 配置文件必须以 -config.json 结尾


# 注意: MCPO不支持--hot-reload参数，此配置已禁用
MCPO_HOT_RELOAD=false

# MCPO 高级配置
# 注意：代码中使用的是 MCPO_TIMEOUT，不是 MCPO_REQUEST_TIMEOUT
# MCPO_TIMEOUT 单位是毫秒，代码会除以1000转换为秒
# 300000毫秒 = 300秒 = 5分钟
MCPO_TIMEOUT=300000
MCPO_MAX_RETRIES=3
MCPO_HEALTH_CHECK_INTERVAL=60
